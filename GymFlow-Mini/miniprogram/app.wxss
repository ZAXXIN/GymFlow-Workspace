*/

/* 全局page样式 - 统一背景 */
page {
  height: 100%;
  min-height: 100%;
  color: #303133;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  /* 全局背景渐变（核心） */
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%) !important;
  position: relative;
}

/* page-layout组件基础样式 */
page-layout {
  display: block;
  min-height: 100vh;
  position: relative;
  background: transparent !important;
  width: 100%;
}

/* 全局背景装饰组件样式 */
.global-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  z-index: 1;
  pointer-events: none;
}

.global-bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(7, 193, 96, 0.1);
}

.global-bg-circle-1 {
  width: 600rpx;
  height: 600rpx;
  top: -200rpx;
  right: -200rpx;
}

.global-bg-circle-2 {
  width: 400rpx;
  height: 400rpx;
  bottom: -100rpx;
  left: -100rpx;
  background: rgba(7, 193, 96, 0.05);
}

/* 页面内容容器 - 确保在背景之上 */
.page-content {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  background: transparent !important;
}

/* 通用页面容器样式 */
.member-home,
.coach-home,
.login-page {
  position: relative;
  z-index: 2;
  background: transparent !important;
  min-height: 100vh;
}

/* 基础布局样式 */
.container {
  padding: 24rpx;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 章节标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 24rpx;
  position: relative;
}
.section-title::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -8rpx;
  width: 60rpx;
  height: 4rpx;
  background: #07c160;
  border-radius: 4rpx;
}

/* 按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s;
}
.btn-primary {
  background: #07c160;
  color: #fff;
}
.btn-primary:active {
  background: #06ae54;
}
.btn-primary[disabled] {
  opacity: 0.5;
  pointer-events: none;
}
.btn-default {
  background: #fff;
  border: 2rpx solid #dcdfe6;
  color: #303133;
}
.btn-default:active {
  background: #fafafa;
}
.btn-block {
  width: 100%;
}
.btn-large {
  height: 88rpx;
  font-size: 32rpx;
}
.btn-small {
  height: 60rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}
.status-tag-pending {
  background: #fff7e6;
  color: #fa8c16;
  border: 1rpx solid #ffd591;
}
.status-tag-success {
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}
.status-tag-info {
  background: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #91d5ff;
}
.status-tag-warning {
  background: #fff2f0;
  color: #fa8c16;
  border: 1rpx solid #ffccc7;
}
.status-tag-completed {
  background: #f5f5f5;
  color: #909399;
  border: 1rpx solid #d9d9d9;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #dcdfe6;
}
.list-item:last-child {
  border-bottom: none;
}
.list-item-content {
  flex: 1;
}
.list-item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #303133;
  margin-bottom: 8rpx;
}
.list-item-desc {
  font-size: 26rpx;
  color: #909399;
}
.list-item-extra {
  margin-left: 24rpx;
  font-size: 28rpx;
  color: #909399;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.empty-state-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
.empty-state-text {
  font-size: 28rpx;
  color: #c0c4cc;
}

/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
}
.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #dcdfe6;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 16rpx;
}
.loading-text {
  font-size: 28rpx;
  color: #909399;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}