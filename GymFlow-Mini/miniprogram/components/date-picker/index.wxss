.date-picker {
  display: inline-block;
  width: 100%;
}

.date-picker-input {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #333;
}

.date-picker-placeholder {
  color: #999;
}

/* 自定义picker样式 */
.date-picker-actions {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.date-picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.date-picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}

.date-picker-header {
  display: flex;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.date-picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.date-picker-confirm {
  font-size: 28rpx;
  color: #07c160;
}

.date-picker-view {
  height: 400rpx;
  width: 100%;
}

.date-picker-column-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: 32rpx;
  color: #333;
}