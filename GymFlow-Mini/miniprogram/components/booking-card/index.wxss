.booking-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 头部 */
.booking-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.booking-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.booking-card-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  white-space: nowrap;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
  border: 2rpx solid #ffd591;
}

.status-success {
  background: #f6ffed;
  color: #52c41a;
  border: 2rpx solid #b7eb8f;
}

.status-completed {
  background: #f5f5f5;
  color: #999;
  border: 2rpx solid #d9d9d9;
}

.status-warning {
  background: #fff2f0;
  color: #f56c6c;
  border: 2rpx solid #ffccc7;
}

/* 内容 */
.booking-card-content {
  padding: 24rpx;
}

.booking-card-info-item {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.booking-card-info-item:last-child {
  margin-bottom: 0;
}

.booking-card-info-label {
  width: 140rpx;
  color: #999;
  flex-shrink: 0;
}

.booking-card-info-value {
  flex: 1;
  color: #333;
}

/* 操作按钮 */
.booking-card-actions {
  display: flex;
  padding: 16rpx 24rpx 24rpx;
  border-top: 2rpx solid #f5f5f5;
}

.booking-card-action {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0 8rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
  text-align: center;
}

.booking-card-action::after {
  border: none;
}

.booking-card-action-cancel {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

.booking-card-action-checkin {
  background: #07c160;
  color: #fff;
}