.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-state-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-state-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.empty-state-button {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.empty-state-button::after {
  border: none;
}