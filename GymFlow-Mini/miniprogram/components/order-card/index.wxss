.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 头部 */
.order-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.order-card-header-left {
  display: flex;
  flex-direction: column;
}

.order-card-order-no {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.order-card-type {
  font-size: 24rpx;
  color: #999;
}

.order-card-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

/* 商品信息 */
.order-card-products {
  padding: 24rpx;
}

.order-card-product {
  display: flex;
  margin-bottom: 16rpx;
}

.order-card-product:last-child {
  margin-bottom: 0;
}

.order-card-product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.order-card-product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.order-card-product-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.order-card-product-spec {
  font-size: 24rpx;
  color: #999;
}

/* 金额信息 */
.order-card-amount {
  padding: 16rpx 24rpx 24rpx;
  text-align: right;
  border-top: 2rpx solid #f5f5f5;
}

.order-card-amount-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.order-card-amount-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #f56c6c;
}

/* 支付信息 */
.order-card-payment {
  display: flex;
  justify-content: space-between;
  padding: 0 24rpx 24rpx;
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.order-card-actions {
  display: flex;
  padding: 0 24rpx 24rpx;
}

.order-card-action {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0 8rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
  text-align: center;
}

.order-card-action::after {
  border: none;
}

.order-card-action-cancel {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

.order-card-action-pay {
  background: #07c160;
  color: #fff;
}