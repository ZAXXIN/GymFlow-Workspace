.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  border-top: 1rpx solid #e5e5e5;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #999999;
}

.tab-item.active .tab-text {
  color: #07c160;
}

.badge {
  position: absolute;
  top: 12rpx;
  right: 50%;
  transform: translateX(30rpx);
  min-width: 32rpx;
  height: 32rpx;
  background-color: #ff4444;
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
  line-height: 32rpx;
  padding: 0 8rpx;
  white-space: nowrap;
}