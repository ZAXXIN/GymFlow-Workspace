.message-badge {
  position: relative;
  display: inline-block;
}

.message-badge-dot {
  position: absolute;
  top: 0;
  right: 0;
  width: 16rpx;
  height: 16rpx;
  background: #f56c6c;
  border-radius: 50%;
  transform: translate(50%, -50%);
}

.message-badge-count {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 6rpx;
  background: #f56c6c;
  color: #fff;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  transform: translate(50%, -50%);
  white-space: nowrap;
}