.product-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 轮播图 */
.product-detail-swiper {
  position: relative;
  height: 750rpx;
  background: #f8f8f8;
}

.product-detail-swiper-image {
  width: 100%;
  height: 100%;
}

.product-detail-tag {
  position: absolute;
  top: 32rpx;
  left: 32rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #fff;
  border-radius: 30rpx;
  z-index: 10;
}

.product-detail-tag-0 {
  background: #07c160;
}

.product-detail-tag-1 {
  background: #409EFF;
}

.product-detail-tag-2 {
  background: #E6A23C;
}

.product-detail-tag-3 {
  background: #f56c6c;
}

/* 商品信息 */
.product-detail-info {
  background: #fff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.product-detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.product-detail-name {
  flex: 1;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.product-detail-sales {
  font-size: 26rpx;
  color: #999;
}

.product-detail-price {
  margin-bottom: 24rpx;
}

.product-detail-price-current {
  font-size: 48rpx;
  font-weight: 600;
  color: #f56c6c;
  margin-right: 16rpx;
}

.product-detail-price-original {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
  margin-right: 16rpx;
}

.product-detail-price-discount {
  font-size: 26rpx;
  padding: 4rpx 12rpx;
  background: #fff2f0;
  color: #f56c6c;
  border-radius: 20rpx;
}

.product-detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.product-detail-meta-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.product-detail-meta-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
  opacity: 0.5;
}

/* 通用区块 */
.product-detail-section {
  background: #fff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.product-detail-section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 商品描述 */
.product-detail-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 课程信息 */
.product-detail-course-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.product-detail-course-item:last-child {
  border-bottom: none;
}

.product-detail-course-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #999;
}

.product-detail-course-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 会籍权益 */
.product-detail-benefits {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.product-detail-benefits-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.product-detail-benefits-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.product-detail-benefits-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.product-detail-benefits-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

/* 使用规则 */
.product-detail-rules,
.product-detail-refund {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  background: #f8f8f8;
  padding: 24rpx;
  border-radius: 16rpx;
}

/* 底部操作栏 */
.product-detail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.product-detail-footer-info {
  flex: 1;
}

.product-detail-footer-price {
  font-size: 40rpx;
  font-weight: 600;
  color: #f56c6c;
  margin-right: 16rpx;
}

.product-detail-footer-original {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
}

.product-detail-footer-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 40rpx;
  margin: 0;
}

.product-detail-footer-btn::after {
  border: none;
}

/* 加载 */
.product-detail-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}