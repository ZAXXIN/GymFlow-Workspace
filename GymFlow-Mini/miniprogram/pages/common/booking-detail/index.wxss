.booking-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 头部 */
.booking-detail-header {
  position: relative;
  height: 240rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a54e 100%);
  padding: 0 32rpx;
}

.booking-detail-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml;base64,');
  opacity: 0.3;
}

.booking-detail-header-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  align-items: center;
}

.booking-detail-status-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.booking-detail-status-icon image {
  width: 60rpx;
  height: 60rpx;
}

.booking-detail-status-info {
  flex: 1;
}

.booking-detail-status-text {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.booking-detail-status-time {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 卡片 */
.booking-detail-card {
  background: #fff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.booking-detail-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.booking-detail-course-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.booking-detail-course-type {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 20rpx;
}

.booking-detail-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 信息列表 */
.booking-detail-info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.booking-detail-info-item {
  display: flex;
  align-items: center;
}

.booking-detail-info-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.booking-detail-info-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #999;
}

.booking-detail-info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.booking-detail-code {
  font-size: 36rpx;
  font-weight: 600;
  color: #07c160;
  letter-spacing: 4rpx;
}

/* 会员信息 */
.booking-detail-member {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.booking-detail-member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  background: #f0f0f0;
}

.booking-detail-member-avatar image {
  width: 100%;
  height: 100%;
}

.booking-detail-member-info {
  flex: 1;
}

.booking-detail-member-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.booking-detail-member-phone {
  font-size: 26rpx;
  color: #999;
}

.booking-detail-member-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

/* 操作按钮 */
.booking-detail-actions {
  margin: 48rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.booking-detail-btn {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 44rpx;
  text-align: center;
}

.booking-detail-btn::after {
  border: none;
}

.booking-detail-btn-cancel {
  background: #fff;
  color: #f56c6c;
  border: 2rpx solid #f56c6c;
}

.booking-detail-btn-checkin {
  background: #07c160;
  color: #fff;
}

.booking-detail-btn-back {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

/* 加载 */
.booking-detail-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}