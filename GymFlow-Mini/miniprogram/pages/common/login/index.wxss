.login-page {
  min-height: 100vh;
  width: 100%;
  height: auto;
  /* background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%); */
  background: transparent;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* 返回按钮 */
.login-back {
  position: absolute;
  top: 60rpx;
  left: 24rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.login-back-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 头部 */
.login-header {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  margin-bottom: 80rpx;
}

.login-logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.login-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.login-slogan {
  font-size: 28rpx;
  color: #999;
}

/* 表单 */
.login-form {
  position: relative;
  z-index: 1;
  padding: 0 48rpx;
}

.login-input-group {
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 0;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.login-input-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.login-input-item:last-child {
  border-bottom: none;
}

.login-input-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
  opacity: 0.5;
}

.login-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
}

.login-input-placeholder {
  color: #ccc;
  font-size: 28rpx;
}

.login-input-eye {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.5;
}

/* 协议同意 */
.login-agreement {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.login-agreement-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-agreement-checkbox.checked {
  background: #07c160;
  border-color: #07c160;
}

.login-agreement-checkbox-icon {
  width: 24rpx;
  height: 24rpx;
}

.login-agreement-text {
  font-size: 26rpx;
  color: #666;
}

.login-agreement-link {
  color: #07c160;
}

/* 登录按钮 */
.login-button {
  height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  border: none;
}

.login-button::after {
  border: none;
}

.login-button[disabled] {
  opacity: 0.7;
}

.login-button-loading {
  background: #05a54e;
}

/* 其他登录方式 */
.login-other {
  position: relative;
  z-index: 1;
  margin-top: 80rpx;
  padding: 0 48rpx;
}

.login-other-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.login-other-divider::before,
.login-other-divider::after {
  content: '';
  flex: 1;
  height: 2rpx;
  background: #ddd;
}

.login-other-divider-text {
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #999;
}

.login-other-icons {
  display: flex;
  justify-content: center;
}

.login-other-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.login-other-icon image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 8rpx;
}

.login-other-icon text {
  font-size: 24rpx;
  color: #666;
}

/* 底部 */
.login-footer {
  position: relative;
  z-index: 1;
  margin-top: auto;
  padding: 40rpx 0 24rpx;
  text-align: center;
}

.login-footer-text {
  font-size: 24rpx;
  color: #999;
}