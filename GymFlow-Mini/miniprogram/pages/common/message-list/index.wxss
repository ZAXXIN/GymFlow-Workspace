.message-list {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 头部 */
.message-list-header {
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.message-list-tabs {
  display: flex;
  gap: 32rpx;
  flex: 1;
}

.message-list-tab {
  position: relative;
  font-size: 28rpx;
  color: #666;
  padding: 8rpx 0;
}

.message-list-tab-active {
  color: #07c160;
  font-weight: 500;
}

.message-list-tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

.message-list-tab-badge {
  position: absolute;
  top: -16rpx;
  right: -24rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #f56c6c;
  color: #fff;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
}

.message-list-actions {
  display: flex;
  align-items: center;
}

.message-list-action {
  padding: 8rpx;
}

.message-list-action-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.5;
}

/* 消息列表 */
.message-list-content {
  padding: 24rpx;
}

.message-list-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.message-list-item-unread {
  background: #f0f9f0;
}

.message-list-item-icon {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin-right: 24rpx;
}

.message-list-item-icon image {
  width: 100%;
  height: 100%;
}

.message-list-item-dot {
  position: absolute;
  top: 0;
  right: 0;
  width: 16rpx;
  height: 16rpx;
  background: #f56c6c;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

.message-list-item-content {
  flex: 1;
}

.message-list-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.message-list-item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.message-list-item-time {
  font-size: 24rpx;
  color: #999;
}

.message-list-item-preview {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.message-list-item-delete {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.message-list-item:hover .message-list-item-delete {
  opacity: 0.5;
}

.message-list-item-delete image {
  width: 40rpx;
  height: 40rpx;
}

/* 加载更多 */
.message-list-loading,
.message-list-nomore {
  padding: 40rpx 0;
  text-align: center;
}

.message-list-nomore text {
  font-size: 26rpx;
  color: #999;
}