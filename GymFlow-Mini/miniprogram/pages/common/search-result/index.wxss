.search-result {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-result-header {
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

/* 筛选栏 */
.search-result-filter {
  background: #fff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 2rpx solid #f5f5f5;
}

.search-result-filter-tabs {
  display: flex;
  gap: 32rpx;
}

.search-result-filter-tab {
  font-size: 28rpx;
  color: #666;
  padding: 8rpx 0;
}

.search-result-filter-tab-active {
  color: #07c160;
  font-weight: 500;
  position: relative;
}

.search-result-filter-tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

.search-result-filter-sort {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.search-result-filter-sort text {
  font-size: 26rpx;
  color: #666;
  margin-right: 8rpx;
}

.search-result-filter-sort-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

/* 搜索结果 */
.search-result-content {
  padding: 24rpx;
}

.search-result-section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.search-result-section-count {
  font-size: 26rpx;
  font-weight: normal;
  color: #999;
}

/* 商品网格 */
.search-result-product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

/* 课程列表 */
.search-result-course-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.search-result-course-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.search-result-course-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.search-result-course-type {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 20rpx;
}

.search-result-course-info {
  margin-bottom: 16rpx;
}

.search-result-course-info-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.search-result-course-info-item:last-child {
  margin-bottom: 0;
}

.search-result-course-info-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-result-course-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 2rpx solid #f5f5f5;
}

.search-result-course-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #f56c6c;
}

.search-result-course-capacity {
  font-size: 26rpx;
  padding: 6rpx 20rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 30rpx;
}

.search-result-course-capacity-warning {
  background: #fff2f0;
  color: #f56c6c;
}

/* 加载更多 */
.search-result-loading,
.search-result-nomore {
  padding: 40rpx 0;
  text-align: center;
}

.search-result-nomore text {
  font-size: 26rpx;
  color: #999;
}