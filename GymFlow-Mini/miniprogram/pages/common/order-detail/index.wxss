.order-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 头部 */
.order-detail-header {
  position: relative;
  height: 240rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a54e 100%);
  padding: 0 32rpx;
}

.order-detail-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml;base64,');
  opacity: 0.3;
}

.order-detail-header-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  align-items: center;
}

.order-detail-status-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.order-detail-status-icon image {
  width: 60rpx;
  height: 60rpx;
}

.order-detail-status-info {
  flex: 1;
}

.order-detail-status-text {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.order-detail-status-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 卡片 */
.order-detail-card {
  background: #fff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.order-detail-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.order-detail-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.order-detail-order-no {
  font-size: 26rpx;
  color: #999;
}

/* 信息列表 */
.order-detail-info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-detail-info-item {
  display: flex;
  align-items: center;
}

.order-detail-info-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.order-detail-info-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #999;
}

.order-detail-info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.order-detail-price {
  color: #f56c6c;
  font-weight: 600;
}

/* 商品列表 */
.order-detail-product-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.order-detail-product-item:last-child {
  border-bottom: none;
}

.order-detail-product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 24rpx;
  background: #f8f8f8;
}

.order-detail-product-image image {
  width: 100%;
  height: 100%;
}

.order-detail-product-info {
  flex: 1;
}

.order-detail-product-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.order-detail-product-name {
  font-size: 30rpx;
  color: #333;
}

.order-detail-product-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #f56c6c;
}

.order-detail-product-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-detail-product-type {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.order-detail-product-quantity {
  font-size: 26rpx;
  color: #999;
}

.order-detail-product-total {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.order-detail-product-total-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
}

.order-detail-product-total-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #f56c6c;
}

/* 操作按钮 */
.order-detail-actions {
  margin: 48rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-detail-btn {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 44rpx;
  text-align: center;
}

.order-detail-btn::after {
  border: none;
}

.order-detail-btn-pay {
  background: #07c160;
  color: #fff;
}

.order-detail-btn-cancel {
  background: #fff;
  color: #f56c6c;
  border: 2rpx solid #f56c6c;
}

.order-detail-btn-confirm {
  background: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
}

.order-detail-btn-back {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

/* 加载 */
.order-detail-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}