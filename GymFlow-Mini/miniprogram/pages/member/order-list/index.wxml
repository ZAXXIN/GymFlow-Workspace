<view class="order-list-page">
  <!-- 统计卡片 -->
  <view class="order-list-stats">
    <!-- 新增：全部卡片 -->
    <view class="order-list-stats-item" data-status="" bindtap="onStatusFilter">
      <text class="order-list-stats-value">{{stats.total}}</text>
      <text class="order-list-stats-label">全部</text>
    </view>
    <view class="order-list-stats-item" data-status="PENDING" bindtap="onStatusFilter">
      <text class="order-list-stats-value">{{stats.pending}}</text>
      <text class="order-list-stats-label">待支付</text>
    </view>
    <view class="order-list-stats-item" data-status="PROCESSING" bindtap="onStatusFilter">
      <text class="order-list-stats-value">{{stats.processing}}</text>
      <text class="order-list-stats-label">处理中</text>
    </view>
    <view class="order-list-stats-item" data-status="COMPLETED" bindtap="onStatusFilter">
      <text class="order-list-stats-value">{{stats.completed}}</text>
      <text class="order-list-stats-label">已完成</text>
    </view>
    <view class="order-list-stats-item" data-status="CANCELLED" bindtap="onStatusFilter">
      <text class="order-list-stats-value">{{stats.cancelled}}</text>
      <text class="order-list-stats-label">已取消</text>
    </view>
  </view>
  
  <!-- 筛选栏 -->
  <!-- <view class="order-list-filter">
    <view class="order-list-filter-status" bindtap="onStatusFilter">
      <text class="order-list-filter-status-label">
        {{statusFilterText}}
      </text>
      <image class="order-list-filter-status-icon" src="/assets/icons/arrow-down.png" mode="aspectFit"></image>
    </view>
  </view> -->
  
  <!-- 订单列表 -->
  <view class="order-list">
    <block wx:for="{{orders}}" wx:key="id" wx:for-item="item">
      <view class="order-list-item" data-order="{{item}}" bindtap="onOrderTap">
        <!-- 订单头部 -->
        <view class="order-list-item-header">
          <view class="order-list-item-header-left">
            <text class="order-list-item-order-no">{{item.orderNo}}</text>
            <text class="order-list-item-type">{{item.orderTypeDesc}}</text>
          </view>
          <text class="order-list-item-status {{getStatusClass(item.orderStatus)}}">
            {{item.orderStatusDesc}}
          </text>
        </view>
        
        <!-- 商品信息 -->
        <view class="order-list-item-products">
          <block wx:for="{{item.items}}" wx:key="id" wx:for-item="product">
            <view class="order-list-item-product">
              <image class="order-list-item-product-image" src="{{product.productImage || '/assets/icons/product-default.jpg'}}" mode="aspectFill"></image>
              <view class="order-list-item-product-info">
                <view class="order-list-item-product-name">{{product.productName}}</view>
                <view class="order-list-item-product-spec">
                  ¥{{product.unitPrice}} × {{product.quantity}}
                </view>
              </view>
            </view>
          </block>
        </view>
        
        <!-- 订单金额 -->
        <view class="order-list-item-amount">
          <text class="order-list-item-amount-label">共{{item.items ? item.items.length : 0}}件商品 实付</text>
          <text class="order-list-item-amount-value">¥{{item.actualAmount}}</text>
        </view>
        
        <!-- 操作按钮 -->
        <view class="order-list-item-actions" catchtap>
          <button 
            class="order-list-item-action order-list-item-action-cancel"
            wx:if="{{item.paymentStatus === 0}}"
            bindtap="onCancelOrder"
            data-order="{{item}}"
          >取消订单</button>
          <button 
            class="order-list-item-action order-list-item-action-pay"
            wx:if="{{item.paymentStatus === 0}}"
            bindtap="onPayOrder"
            data-order="{{item}}"
          >立即支付</button>
          <button 
            class="order-list-item-action order-list-item-action-confirm"
            wx:if="{{item.orderStatus === 'PROCESSING' && item.orderType !== 3}}"
            bindtap="onConfirmReceive"
            data-order="{{item}}"
          >确认完成</button>
        </view>
      </view>
    </block>

    <!-- 错误状态 -->
    <view class="order-list-error" wx:if="{{error}}">
      <image src="/assets/icons/error.png" mode="aspectFit"></image>
      <text>{{error}}</text>
      <button class="order-list-retry-btn" bindtap="onRetry">重试</button>
    </view>
    
    <!-- 加载中 -->
    <view class="order-list-loading" wx:if="{{loading}}">
      <loading type="circular" text="加载中..."></loading>
    </view>
    
    <!-- 没有更多 -->
    <view class="order-list-nomore" wx:if="{{!hasMore && orders.length > 0}}">
      <text>没有更多了</text>
    </view>
    
    <!-- 空状态 -->
    <empty-state 
      wx:if="{{!loading && orders.length === 0}}"
      show="{{true}}"
      text="暂无订单"
    ></empty-state>
    <!--       buttonText="去逛逛"
      bindbuttonTap="goToHome" -->
  </view>
</view>