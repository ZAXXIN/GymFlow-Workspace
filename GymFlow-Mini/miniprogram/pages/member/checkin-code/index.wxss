.checkin-code-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 头部 */
.checkin-code-header {
  position: relative;
  height: 280rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a54e 100%);
  padding: 0 32rpx;
}

.checkin-code-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml;base64,');
  opacity: 0.3;
}

.checkin-code-header-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.checkin-code-course-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.checkin-code-course-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 16rpx;
}

.checkin-code-course-type {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 20rpx;
}

.checkin-code-time,
.checkin-code-location {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.checkin-code-time-icon,
.checkin-code-location-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

/* 签到码卡片 */
.checkin-code-card {
  background: #fff;
  margin: -60rpx 32rpx 0;
  padding: 48rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 2;
}

.checkin-code-qrcode {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-code-qrcode-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-code-number {
  text-align: center;
  margin-bottom: 32rpx;
  padding: 24rpx 0;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.checkin-code-number-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.checkin-code-number-value {
  font-size: 60rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 8rpx;
}

.checkin-code-expire {
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-code-expire-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.checkin-code-expire-text {
  font-size: 26rpx;
  color: #f56c6c;
}

/* 使用说明 */
.checkin-code-guide {
  margin: 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.checkin-code-guide-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.checkin-code-guide-item {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.checkin-code-guide-item:last-child {
  margin-bottom: 0;
}

.checkin-code-guide-dot {
  width: 40rpx;
  color: #07c160;
}

.checkin-code-guide-text {
  flex: 1;
}

/* 底部按钮 */
.checkin-code-footer {
  margin: 48rpx 32rpx 32rpx;
  display: flex;
  gap: 24rpx;
}

.checkin-code-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 44rpx;
  text-align: center;
}

.checkin-code-btn::after {
  border: none;
}

.checkin-code-btn-cancel {
  background: #fff;
  color: #f56c6c;
  border: 2rpx solid #f56c6c;
}

.checkin-code-btn-back {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}