/* 预约页面样式 */
.booking-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* 固定头部区域 */
.booking-fixed-header {
  flex-shrink: 0;
  z-index: 10;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

/* 筛选栏（课程类型选择器 + 时间选择器） */
.booking-search {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  /* background-color: #fff; */
  border-bottom: 1px solid #f0f0f0;
}

/* 课程类型选择器 - 左侧 */
.booking-course-type-select {
  flex-shrink: 0;
  margin-right: 12px;
}

.booking-course-type-picker {
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 8px;
  padding: 8px 12px;
  font-size: 14px;
  font-weight: 500;
  color: #333;
}

/* 右侧筛选器容器 */
.booking-filter-right {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

/* 日期选择器 */
.booking-date-picker {
  width: auto;
}

.booking-date-picker-inner {
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 8px;
  padding: 8px 12px;
  font-size: 14px;
  color: #333;
}

.booking-date-icon {
  width: 18px;
  height: 18px;
  margin-right: 6px;
}

.booking-date-text {
  margin-right: 6px;
}

/* 教练选择器 */
.booking-coach-select {
  width: auto;
}

.booking-coach-picker {
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 8px;
  padding: 8px 12px;
  font-size: 14px;
  color: #333;
}

.booking-coach-icon {
  width: 18px;
  height: 18px;
  margin-right: 6px;
}

/* 公共箭头样式 */
.booking-picker-arrow {
  width: 14px;
  height: 14px;
  margin-left: 6px;
}

/* 状态Tab样式 - 固定在头部 */
.booking-status-tabs {
  width: 100%;
  border-bottom: 2rpx solid #f5f5f5;
}

.booking-status-tabs-container {
  display: flex;
  align-items: center;
  height: 88rpx;
}

.booking-status-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: color 0.3s;
  line-height: 88rpx;
  text-align: center;
}

.booking-status-tab-active {
  color: #07c160;
  font-weight: 500;
}

.booking-status-tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background-color: #07c160;
  border-radius: 2rpx;
}

.booking-status-tab-text {
  line-height: 1;
  display: inline-block;
}

/* 可滚动内容区域 */
.booking-scroll-content {
  flex: 1;
  height: 0;
}

/* Tab内容区域 */
.booking-tab-content {
  padding: 24rpx 0 0;
}

/* 课程列表 */
.booking-course-list {
  padding: 0 24rpx;
}

.booking-course-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.booking-course-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.booking-course-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.booking-course-tag {
  font-size: 24rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.booking-course-info {
  margin-bottom: 16rpx;
}

.booking-course-info-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.booking-course-info-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.booking-course-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}

.booking-course-capacity {
  font-size: 26rpx;
  color: #999;
  display: flex;
}

.booking-course-capacity-warning {
  color: #e6a23c;
}

.capacity-text{
  display: block;
  margin-left: 20rpx;
}

/* 预约列表 */
.booking-list {
  padding: 0 24rpx;
}

/* 加载中 */
.booking-loading {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

/* 底部安全区域 */
.booking-safe-bottom {
  height: env(safe-area-inset-bottom);
}

/* 预约弹窗 */
.booking-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.booking-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.booking-modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.booking-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.booking-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.booking-modal-close {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.5;
}

.booking-modal-body {
  padding: 32rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.booking-modal-info-item {
  display: flex;
  margin-bottom: 24rpx;
}

.booking-modal-info-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #999;
}

.booking-modal-info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.booking-modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #f0f0f0;
}

.booking-modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin: 0 12rpx;
}

.booking-modal-btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.booking-modal-btn-confirm {
  background: #07c160;
  color: #fff;
}

.booking-modal-btn-confirm[disabled] {
  opacity: 0.5;
}

/* 签到码弹窗样式 */
.checkin-modal-content {
  width: 680rpx !important;
}

.checkin-code-header-content {
  background: linear-gradient(135deg, #07c160, #059c4a);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  text-align: center;
  color: #fff;
}

.checkin-code-course-info {
  margin-bottom: 20rpx;
}

.checkin-code-course-name {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.checkin-code-course-type {
  font-size: 24rpx;
  opacity: 0.9;
}

.checkin-code-time {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.checkin-code-time-icon {
  width: 32rpx;
  height: 32rpx;
}

.checkin-code-qrcode {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.checkin-code-number {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.checkin-code-number-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.checkin-code-number-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 8rpx;
}

.checkin-code-expire {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #fff5e6;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.checkin-code-expire-icon {
  width: 32rpx;
  height: 32rpx;
}

.checkin-code-expire-text {
  font-size: 24rpx;
  color: #e6a23c;
}

.booking-modal-btn-warning {
  background: #e6a23c;
  color: #fff;
}

.booking-modal-btn-warning[disabled] {
  opacity: 0.5;
}