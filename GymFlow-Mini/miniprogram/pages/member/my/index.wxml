    <!-- 退出登录按钮 -->
    <view class="member-my-logout" bindtap="onLogout">
      <text>退出登录</text>
    </view>
    
    <!-- 底部版权 -->
    <view class="member-my-footer">
      <text class="member-my-footer-text">© 2026 GymFlow 健身管理系统</text>
    </view>
  </view>
</page-layout>