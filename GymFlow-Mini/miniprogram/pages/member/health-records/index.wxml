<view class="health-records-page">
  <!-- 统计卡片 -->
  <view class="health-records-stats" wx:if="{{records.length > 0}}">
    <view class="health-records-stats-item">
      <text class="health-records-stats-label">最新体重</text>
      <view class="health-records-stats-value-wrapper">
        <text class="health-records-stats-value">{{stats.latestWeight}}</text>
        <text class="health-records-stats-unit">kg</text>
      </view>
    </view>
    
    <view class="health-records-stats-item">
      <text class="health-records-stats-label">体脂率</text>
      <view class="health-records-stats-value-wrapper">
        <text class="health-records-stats-value">{{stats.latestBodyFat}}</text>
        <text class="health-records-stats-unit">%</text>
      </view>
    </view>
    
    <view class="health-records-stats-item">
      <text class="health-records-stats-label">记录次数</text>
      <text class="health-records-stats-value-large">{{stats.recordCount}}</text>
    </view>
  </view>
  
  <!-- 记录列表 -->
  <view class="health-records-list">
    <block wx:for="{{records}}" wx:key="id">
      <view class="health-records-item" data-record="{{item}}" bindtap="onRecordTap">
        <view class="health-records-item-header">
          <text class="health-records-item-date">{{item.recordDate}}</text>
          <image class="health-records-item-arrow" src="/assets/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
        
        <view class="health-records-item-content">
          <view class="health-records-item-metric">
            <text class="health-records-item-metric-label">体重</text>
            <text class="health-records-item-metric-value">{{item.weight}}kg</text>
          </view>
          <view class="health-records-item-metric">
            <text class="health-records-item-metric-label">体脂率</text>
            <text class="health-records-item-metric-value">{{item.bodyFatPercentage}}%</text>
          </view>
          <view class="health-records-item-metric">
            <text class="health-records-item-metric-label">BMI</text>
            <text class="health-records-item-metric-value">{{item.bmi}}</text>
          </view>
        </view>
        
        <view class="health-records-item-footer" wx:if="{{item.notes}}">
          <text class="health-records-item-notes">{{item.notes}}</text>
        </view>
      </view>
    </block>
    
    <!-- 加载中 -->
    <view class="health-records-loading" wx:if="{{loading}}">
      <loading type="circular" text="加载中..."></loading>
    </view>
    
    <!-- 空状态 -->
    <empty-state 
      wx:if="{{!loading && records.length == 0}}"
      show="{{true}}"
      text="暂无健康记录"
    ></empty-state>
  </view>
</view>