.card-detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

/* 会员卡样式 */
.card-info-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 24rpx;
}

.card-info-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.card-info-card-content {
  position: relative;
  z-index: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  color: #fff;
  min-height: 320rpx;
}

.card-info-card-type {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.card-info-card-number {
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 8rpx;
}

.card-info-card-name {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: auto;
}

.card-info-card-footer {
  margin-top: 24rpx;
}

.card-info-card-date,
.card-info-card-sessions {
  font-size: 22rpx;
  opacity: 0.7;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.stats-card-two {
  display: flex;
  text-align: center;
}

.stats-item {
  flex: 1;
}

.stats-divider {
  width: 2rpx;
  background: #f0f0f0;
  margin: 0 32rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.stats-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #07c160;
  margin-right: 8rpx;
}

.stats-unit {
  font-size: 28rpx;
  color: #999;
}

/* 记录列表 */
.record-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item-left {
  display: flex;
  flex-direction: column;
}

.record-item-date,
.record-item-time {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.record-item-method,
.record-item-course {
  font-size: 24rpx;
  color: #999;
}

.record-item-type {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.session-consume .record-item-type {
  color: #f56c6c;
}

.session-return .record-item-type {
  color: #67c23a;
}

.record-item-badge {
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.record-item-sessions {
  font-size: 28rpx;
  font-weight: 500;
}

.session-consume .record-item-sessions {
  color: #f56c6c;
}

.session-return .record-item-sessions {
  color: #67c23a;
}

.loading-wrapper {
  padding: 60rpx 0;
  display: flex;
  justify-content: center;
}