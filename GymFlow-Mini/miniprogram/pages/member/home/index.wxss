.member-home {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 头部 */
.member-home-header {
  /* background: #fff; */
  padding: 24rpx 24rpx 16rpx;
  position: relative;
  z-index: 10;
}

.member-home-header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.member-home-header-left {
  display: flex;
  flex-direction: column;
}

.member-home-greeting {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.member-home-date {
  font-size: 26rpx;
  color: #999;
}

.member-home-header-right {
  display: flex;
  align-items: center;
}

.member-home-message {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-home-message-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 提醒卡片 */
.member-home-reminder {
  margin: 16rpx 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a54e 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.member-home-reminder-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.member-home-reminder-icon image {
  width: 48rpx;
  height: 48rpx;
}

.member-home-reminder-content {
  flex: 1;
}

.member-home-reminder-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.member-home-reminder-info {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
}

.member-home-reminder-course {
  margin-right: 16rpx;
}

.member-home-reminder-time {
  font-size: 26rpx;
  font-weight: normal;
  opacity: 0.9;
  margin-right: 16rpx;
}

.member-home-reminder-coach {
  font-size: 26rpx;
  font-weight: normal;
  opacity: 0.9;
}

.member-home-reminder-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.member-home-reminder-arrow image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.8;
}

/* 商品列表 */
.member-home-products {
  padding: 0 24rpx 50rpx 24rpx;
}

.member-home-products-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -12rpx;
}

.member-home-products-grid-item {
  width: 50%;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.member-home-products-loading {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
}

.member-home-products-nomore {
  padding: 40rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}