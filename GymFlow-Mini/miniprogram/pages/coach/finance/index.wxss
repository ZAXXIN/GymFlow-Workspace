.coach-finance {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 32rpx;
}

/* 周期切换 */
.coach-finance-period {
  background: #fff;
  padding: 24rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 统计卡片 */
.coach-finance-cards {
  padding: 24rpx 32rpx;
}

.coach-finance-card-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.coach-finance-card-row stat-card {
  flex: 1;
}

/* 加载 */
.coach-finance-loading {
  padding: 80rpx 0;
  text-align: center;
}

/* 图表区域 */
.coach-finance-charts {
  margin: 0 32rpx;
}

.coach-finance-charts chart-card {
  margin-bottom: 24rpx;
  display: block;
}

/* 日期范围 */
.coach-finance-range {
  margin: 24rpx 32rpx 0;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.coach-finance-range-text {
  font-size: 26rpx;
  color: #999;
}