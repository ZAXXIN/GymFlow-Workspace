.coach-member-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 32rpx;
}

/* 头部 */
.coach-member-header {
  position: relative;
  height: 240rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a54e 100%);
  padding: 0 32rpx;
}

.coach-member-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml;base64,');
  opacity: 0.3;
}

.coach-member-header-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  align-items: center;
}

.coach-member-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  overflow: hidden;
  margin-right: 24rpx;
  background: #f0f0f0;
}

.coach-member-avatar image {
  width: 100%;
  height: 100%;
}

.coach-member-info {
  flex: 1;
}

.coach-member-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.coach-member-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 4rpx;
}

.coach-member-no {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 通用区块 */
.coach-member-section {
  background: #fff;
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.coach-member-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.coach-member-section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.coach-member-section-more {
  font-size: 26rpx;
  color: #07c160;
}

/* 会员卡信息 */
.coach-member-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 24rpx;
}

.coach-member-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.coach-member-card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.coach-member-card-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.coach-member-card-status-active {
  background: #52c41a;
  color: #fff;
}

.coach-member-card-status-expired {
  background: #999;
  color: #fff;
}

.coach-member-card-status-used-up {
  background: #f56c6c;
  color: #fff;
}

.coach-member-card-info {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 16rpx;
}

.coach-member-card-info-item {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.coach-member-card-info-item:last-child {
  margin-bottom: 0;
}

.coach-member-card-info-label {
  width: 140rpx;
  color: rgba(255, 255, 255, 0.8);
}

.coach-member-card-info-value {
  flex: 1;
  color: #fff;
}

/* 课程记录 */
.coach-member-course-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.coach-member-course-item:last-child {
  border-bottom: none;
}

.coach-member-course-time {
  width: 160rpx;
  display: flex;
  flex-direction: column;
}

.coach-member-course-date {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.coach-member-course-time-range {
  font-size: 24rpx;
  color: #999;
}

.coach-member-course-info {
  flex: 1;
  margin-left: 24rpx;
}

.coach-member-course-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.coach-member-course-name {
  font-size: 30rpx;
  color: #333;
}

.coach-member-course-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.coach-member-course-status-pending {
  background: #fff2f0;
  color: #f56c6c;
}

.coach-member-course-status-checked {
  background: #e6f7e6;
  color: #07c160;
}

.coach-member-course-status-completed {
  background: #f0f0f0;
  color: #999;
}

.coach-member-course-status-cancelled {
  background: #f0f0f0;
  color: #999;
}

.coach-member-course-detail {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.coach-member-course-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  opacity: 0.5;
}

/* 健康档案 */
.coach-member-health-item {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.coach-member-health-item:last-child {
  margin-bottom: 0;
}

.coach-member-health-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.coach-member-health-date {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.coach-member-health-weight {
  font-size: 32rpx;
  font-weight: 600;
  color: #07c160;
}

.coach-member-health-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #666;
}

.coach-member-health-notes {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}