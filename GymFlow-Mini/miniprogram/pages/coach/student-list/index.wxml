<view class="student-list-page">
  <!-- 课程信息头部 -->
  <view class="student-list-header" wx:if="{{courseInfo}}">
    <view class="student-list-header-bg"></view>
    <view class="student-list-header-content">
      <view class="student-list-course-info">
        <text class="student-list-course-name">{{courseInfo.courseName}}</text>
        <text class="student-list-course-type">{{courseInfo.courseType === 0 ? '私教课' : '团课'}}</text>
      </view>
      <view class="student-list-course-time">
        <image class="student-list-course-icon" src="/assets/icons/time-white.png" mode="aspectFit"></image>
        <text>{{courseInfo.courseDate}} {{formatTime(courseInfo.startTime)}}-{{formatTime(courseInfo.endTime)}}</text>
      </view>
      <view class="student-list-course-location" wx:if="{{courseInfo.location}}">
        <image class="student-list-course-icon" src="/assets/icons/location-white.png" mode="aspectFit"></image>
        <text>{{courseInfo.location}}</text>
      </view>
      <view class="student-list-course-stats">
        <text>已签到 {{checkedCount}}/{{courseInfo.currentEnrollment}}人</text>
      </view>
    </view>
  </view>
  
  <!-- 学员列表 -->
  <view class="student-list-content">
    <!-- Tab切换 -->
    <view class="student-list-tabs">
      <view 
        class="student-list-tab {{activeTab === 0 ? 'student-list-tab-active' : ''}}"
        bindtap="onTabChange"
        data-index="0"
      >
        全部 ({{totalCount}})
      </view>
      <view 
        class="student-list-tab {{activeTab === 1 ? 'student-list-tab-active' : ''}}"
        bindtap="onTabChange"
        data-index="1"
      >
        待签到 ({{pendingCount}})
      </view>
      <view 
        class="student-list-tab {{activeTab === 2 ? 'student-list-tab-active' : ''}}"
        bindtap="onTabChange"
        data-index="2"
      >
        已签到 ({{checkedCount}})
      </view>
    </view>
    
    <!-- 学员列表 -->
    <view class="student-list">
      <block wx:for="{{filteredStudents}}" wx:key="memberId" wx:for-item="student">
        <view class="student-list-item" bindtap="onStudentTap" data-student="{{student}}">
          <view class="student-list-avatar">
            <image src="/assets/icons/avatar-default.png" mode="aspectFill"></image>
            <view class="student-list-status-dot {{student.bookingStatus === 1 ? 'student-list-status-dot-checked' : ''}}"></view>
          </view>
          
          <view class="student-list-info">
            <view class="student-list-header">
              <text class="student-list-name">{{student.memberName}}</text>
              <text class="student-list-status {{student.bookingStatus === 1 ? 'student-list-status-checked' : 'student-list-status-pending'}}">
                {{student.bookingStatus === 1 ? '已签到' : '待签到'}}
              </text>
            </view>
            
            <view class="student-list-detail">
              <view class="student-list-detail-item">
                <image class="student-list-detail-icon" src="/assets/icons/phone.png" mode="aspectFit"></image>
                <text>{{student.memberPhone}}</text>
              </view>
              <view class="student-list-detail-item">
                <image class="student-list-detail-icon" src="/assets/icons/member-no.png" mode="aspectFit"></image>
                <text>NO.{{student.memberNo}}</text>
              </view>
            </view>
            
            <view class="student-list-footer" wx:if="{{student.checkinTime}}">
              <text class="student-list-checkin-time">签到时间: {{formatDateTime(student.checkinTime)}}</text>
            </view>
          </view>
          
          <image class="student-list-arrow" src="/assets/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </block>
      
      <!-- 加载中 -->
      <view class="student-list-loading" wx:if="{{loading}}">
        <loading type="circular" text="加载中..."></loading>
      </view>
      
      <!-- 空状态 -->
      <empty-state 
        wx:if="{{!loading && filteredStudents.length === 0}}"
        show="{{true}}"
        text="暂无学员"
      ></empty-state>
    </view>
  </view>
  
  <!-- 扫码核销按钮 -->
  <view class="student-list-scan" bindtap="onScanTap" wx:if="{{canCheckin}}">
    <image class="student-list-scan-icon" src="/assets/icons/scan.png" mode="aspectFit"></image>
    <text>扫码核销</text>
  </view>
</view>