.coach-my {
  min-height: 100vh;
  background: transparent !important;
  position: relative;
  z-index: 2;
  padding-bottom: 24rpx;
}

/* 头部 */
.coach-my-header {
  position: relative;
  height: 280rpx;
}

.coach-my-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml;base64,');
  opacity: 0.3;
}

.coach-my-header-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 32rpx 32rpx;
  display: flex;
  align-items: center;
  margin-top: -20rpx;
}

.coach-my-info {
  flex: 1;
}

.coach-my-name {
  font-size: 36rpx;
  font-weight: 600;
  color:#333;
  margin-bottom: 4rpx;
}

.coach-my-phone {
  font-size: 26rpx;
  color:#333;
  margin-bottom: 4rpx;
}

.coach-my-specialty {
  font-size: 24rpx;
  color:#333;
}

.coach-my-message {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coach-my-message-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 统计数据 */
.coach-my-stats {
  background: rgba(255, 255, 255, 0.2);
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  display: flex;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.coach-my-stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.coach-my-stats-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.coach-my-stats-label {
  font-size: 24rpx;
  color: #999;
}

/* 通用区块 */
.coach-my-section {
  background: rgba(255, 255, 255, 0.3);
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  z-index: 2;
}

.coach-my-section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 信息列表 */
.coach-my-info-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(255,255,255,0.3);
}

.coach-my-info-item:last-child {
  border-bottom: none;
}

.coach-my-info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
}

.coach-my-info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 证书列表 */
.coach-my-cert-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.coach-my-cert-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 40rpx;
}

.coach-my-cert-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
  opacity: 0.6;
}

.coach-my-cert-name {
  font-size: 26rpx;
  color: #333;
}

/* 个人简介 */
.coach-my-intro {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 菜单列表 */
.coach-my-menu {
  background: rgba(255, 255, 255, 0.3);
  margin: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  z-index: 2;
}

.coach-my-menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid rgba(255,255,255,0.3);
}

.coach-my-menu-item:last-child {
  border-bottom: none;
}

.coach-my-menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
  opacity: 0.6;
}

.coach-my-menu-title {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.coach-my-menu-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

/* 退出登录按钮 */
.coach-my-logout {
  margin: 48rpx 24rpx 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #f56c6c;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  z-index: 2;
}

/* 底部 */
.coach-my-footer {
  padding: 24rpx;
  text-align: center;
}

.coach-my-footer-text {
  font-size: 24rpx;
  color: #999;
}