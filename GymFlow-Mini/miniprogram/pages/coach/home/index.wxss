.coach-home {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 头部 */
.coach-home-header {
  padding: 24rpx 24rpx 16rpx;
  position: relative;
  z-index: 10;
}

.coach-home-header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.coach-home-header-left {
  display: flex;
  flex-direction: column;
}

.coach-home-greeting {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.coach-home-title {
  font-size: 26rpx;
  color: #999;
}

.coach-home-header-right {
  display: flex;
  align-items: center;
}

.coach-home-message {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coach-home-message-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 日期选择 */
.coach-home-date {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.coach-home-date .date-picker {
  flex: 1;
}

.coach-home-today {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 600;
  margin-left: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 16rpx;
}

/* 提醒卡片 */
.coach-home-reminder {
  margin: 16rpx 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a54e 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.coach-home-reminder-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.coach-home-reminder-icon image {
  width: 48rpx;
  height: 48rpx;
}

.coach-home-reminder-content {
  flex: 1;
}

.coach-home-reminder-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.coach-home-reminder-info {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
}

.coach-home-reminder-course {
  margin-right: 16rpx;
}

.coach-home-reminder-time {
  font-size: 26rpx;
  font-weight: normal;
  opacity: 0.9;
}

.coach-home-reminder-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.coach-home-reminder-arrow image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.8;
}

/* 课表列表 */
.coach-home-schedule {
  padding: 0 24rpx 24rpx;
}

.coach-home-schedule-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.coach-home-schedule-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.coach-home-schedule-count {
  font-size: 26rpx;
  color: #999;
}

/* 课程列表项 */
.coach-home-course-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
}

.coach-home-course-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1px solid #f5f5f5;
}

.coach-home-course-item:last-child {
  border-bottom: none;
}

.coach-home-course-time {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.coach-home-course-time-start {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.coach-home-course-time-end {
  font-size: 24rpx;
  color: #999;
}

.coach-home-course-divider {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 24rpx;
}

.coach-home-course-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #07c160;
  margin-bottom: 8rpx;
}

.coach-home-course-line {
  flex: 1;
  width: 2rpx;
  background: #f0f0f0;
}

.coach-home-course-info {
  flex: 1;
}

.coach-home-course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.coach-home-course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.coach-home-course-type {
  font-size: 24rpx;
  color: #fff;
  background: #07c160;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.coach-home-course-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.coach-home-course-detail-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.coach-home-course-detail-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.coach-home-course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.coach-home-course-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  color: #fff;
  background: #07c160;
}

.coach-home-course-students {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #07c160;
}

.coach-home-course-students-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

/* 加载中 & 空状态 */
.coach-home-loading {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
}