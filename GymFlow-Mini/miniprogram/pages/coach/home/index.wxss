.coach-home {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 头部 */
.coach-home-header {
  padding: 24rpx 24rpx 16rpx;
  position: relative;
  z-index: 10;
}

.coach-home-header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.coach-home-header-left {
  display: flex;
  flex-direction: column;
}

.coach-home-greeting {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.coach-home-title {
  font-size: 26rpx;
  color: #999;
}

.coach-home-header-right {
  display: flex;
  align-items: center;
}

.coach-home-message {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coach-home-message-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 日期选择区域 */
.coach-home-date {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16px;
  padding: 0 4px;
}

/* 日期选择器 */
.coach-home-date-picker {
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 8px;
  padding: 8px 12px;
  font-size: 14px;
  color: #333;
  flex: 1;
}

.coach-home-date-icon {
  width: 18px;
  height: 18px;
  margin-right: 6px;
}

.coach-home-date-text {
  flex: 1;
  margin-right: 6px;
  color: #333;
}

.coach-home-date-arrow {
  width: 14px;
  height: 14px;
}

/* 今天按钮 */
.coach-home-today {
  background-color: #07c160;
  border-radius: 8px;
  padding: 3px 9px;
  font-size: 14px;
  color: #fff;
  margin-left: 12px;
}

/* 提醒卡片 */
.coach-home-reminder {
  margin: 16rpx 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a54e 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.coach-home-reminder-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.coach-home-reminder-icon image {
  width: 48rpx;
  height: 48rpx;
}

.coach-home-reminder-content {
  flex: 1;
}

.coach-home-reminder-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.coach-home-reminder-info {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
}

.coach-home-reminder-course {
  margin-right: 16rpx;
}

.coach-home-reminder-time {
  font-size: 26rpx;
  font-weight: normal;
  opacity: 0.9;
}

.coach-home-reminder-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.coach-home-reminder-arrow image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.8;
}

/* 课表列表 */
.coach-home-schedule {
  padding: 0 24rpx 24rpx;
}

.coach-home-schedule-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.coach-home-schedule-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.coach-home-schedule-count {
  font-size: 26rpx;
  color: #999;
}

/* 课程列表项 */
.coach-home-course-list {
  /* background: #fff; */
  border-radius: 24rpx;
  padding: 24rpx;
}

.coach-home-course-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1px solid #f5f5f5;
}

.coach-home-course-item:last-child {
  border-bottom: none;
}

.coach-home-course-time {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.coach-home-course-time-start {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.coach-home-course-time-end {
  font-size: 24rpx;
  color: #999;
}

.coach-home-course-divider {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 24rpx;
}

.coach-home-course-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #07c160;
  margin-bottom: 8rpx;
}

.coach-home-course-line {
  flex: 1;
  width: 2rpx;
  background: #f0f0f0;
}

.coach-home-course-info {
  flex: 1;
}

.coach-home-course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.coach-home-course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.coach-home-course-type {
  font-size: 24rpx;
  color: #fff;
  background: #07c160;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.coach-home-course-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.coach-home-course-detail-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.coach-home-course-detail-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.coach-home-course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.coach-home-course-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  color: #fff;
  background: #07c160;
}

.coach-home-course-students {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #07c160;
}

.coach-home-course-students-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

/* 加载中 & 空状态 */
.coach-home-loading {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
}

/* 签到弹窗样式 */
.checkin-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.checkin-modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 10;
}

.checkin-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.checkin-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.checkin-modal-close {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.5;
}

.checkin-modal-body {
  padding: 32rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.checkin-modal-info-item {
  display: flex;
  margin-bottom: 24rpx;
  align-items: center;
}

.checkin-modal-info-label {
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.checkin-modal-input {
  flex: 1;
}

.checkin-code-input {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx 10rpx;
  font-size: 32rpx;
  text-align: center;
}

.checkin-modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #f0f0f0;
}

.checkin-modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin: 0 12rpx;
}

.checkin-modal-btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.checkin-modal-btn-confirm {
  background: #07c160;
  color: #fff;
}

.checkin-modal-btn-confirm[disabled] {
  opacity: 0.5;
}